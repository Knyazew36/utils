{
  "name": "@front-cmdt/utils",
  "version": "0.0.3",
  "keywords": [
    "format-phone",
    "get-name",
    "number-separator",
    "ms"
  ],
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "license": "ISC",
  "sideEffects": false,
  "engines": {
    "node": ">=14.0.0"
  },
  "peerDependencies": {},
  "dependencies": {},
  "files": [
    "dist",
    "CHANGELOG.md",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "release:patch": "yarn build && npm version patch -m \"release: v%s\" && git push --follow-tags",
    "release:minor": "yarn build && npm version minor -m \"release: v%s\" && git push --follow-tags",
    "release:major": "yarn build && npm version major -m \"release: v%s\" && git push --follow-tags",
    "release:push": "git push --follow-tags",
    "pub:local": "npm run build && yalc push",
    "format": "prettier . --write",
    "test": "vitest",
    "test:run": "vitest run",
    "coverage": "vitest run --coverage",
    "test:browser": "vitest --config=vitest.browser.config.ts"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    },
    "./error-catch": {
      "types": "./dist/error-catch.d.ts",
      "import": "./dist/error-catch.js",
      "require": "./dist/error-catch.cjs",
      "default": "./dist/error-catch.js"
    },
    "./format-phone": {
      "types": "./dist/format-phone.d.ts",
      "import": "./dist/format-phone.js",
      "require": "./dist/format-phone.cjs",
      "default": "./dist/format-phone.js"
    },
    "./get-name": {
      "types": "./dist/get-name.d.ts",
      "import": "./dist/get-name.js",
      "require": "./dist/get-name.cjs",
      "default": "./dist/get-name.js"
    },
    "./number-separator": {
      "types": "./dist/number-separator.d.ts",
      "import": "./dist/number-separator.js",
      "require": "./dist/number-separator.cjs",
      "default": "./dist/number-separator.js"
    },
    "./ms": {
      "types": "./dist/ms.d.ts",
      "import": "./dist/ms.js",
      "require": "./dist/ms.cjs",
      "default": "./dist/ms.js"
    }
  },
  "devDependencies": {
    "@front-cmdt/format": "^1.3.0",
    "@types/node": "^25.1.0",
    "@types/validator": "^13.15.10",
    "@vitest/coverage-v8": "^4.0.18",
    "jsdom": "^27.4.0",
    "prettier": "^3.8.1",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18",
    "yalc": "^1.0.0-pre.53"
  }
}
