{
  "name": "@front-cmdt/utils",
  "version": "0.0.1",
  "keywords": [],
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "license": "ISC",
  "peerDependencies": {},
  "dependencies": {},
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.ts",
  "module": "./dist/index.js",
  "typesVersions": {
    "*": {
      "*": [
        "./dist/index.d.ts"
      ]
    }
  },
  "files": [
    "dist",
    "CHANGELOG.md",
    "README.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "release:patch": "yarn build && npm version patch -m \"release: v%s\" && git push --follow-tags",
    "release:minor": "yarn build && npm version minor -m \"release: v%s\" && git push --follow-tags",
    "release:major": "yarn build && npm version major -m \"release: v%s\" && git push --follow-tags",
    "release:push": "git push --follow-tags",
    "pub:local": "npm run build && yalc push",
    "format": "prettier . --write",
    "test": "vitest",
    "test:run": "vitest run",
    "coverage": "vitest run --coverage",
    "test:browser": "vitest --config=vitest.browser.config.ts"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    }
  },
  "devDependencies": {
    "@front-cmdt/format": "^1.3.0",
    "@types/node": "^25.1.0",
    "@types/validator": "^13.15.10",
    "@vitest/coverage-v8": "^4.0.18",
    "jsdom": "^27.4.0",
    "prettier": "^3.8.1",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18",
    "yalc": "^1.0.0-pre.53"
  }
}
